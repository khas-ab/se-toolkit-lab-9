{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "reasoningEffort": null
    }
  },
  "providers": {
    "custom": {
      "apiKey": "${LLM_API_KEY}",
      "apiBase": "${LLM_API_BASE_URL}",
      "extraHeaders": null
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms", "${NANOBOT_LMS_BACKEND_URL}"],
        "env": {
          "PYTHONPATH": "/app/mcp",
          "NANOBOT_LMS_API_KEY": "${NANOBOT_LMS_API_KEY}"
        }
      },
      "observability": {
        "command": "python",
        "args": ["-m", "mcp_observability"],
        "env": {
          "PYTHONPATH": "/app/mcp",
          "VICTORIALOGS_BASE_URL": "http://victorialogs:9428",
          "VICTORIATRACES_BASE_URL": "http://victoriatraces:10428"
        }
      }
    }
  }
}
